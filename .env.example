# ===== AI API 配置 =====
# AI 提供商: "claude" 或 "openai"
AI_PROVIDER=openai

# Claude API（AI_PROVIDER=claude 时使用）
CLAUDE_API_KEY=
CLAUDE_API_BASE=https://api.anthropic.com
CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenAI / DeepSeek 兼容接口（AI_PROVIDER=openai 时使用）
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat

# ===== 服务配置 =====
HOST=0.0.0.0
PORT=8005
CORS_ORIGINS=http://localhost:3000

# ===== 数据库 =====
# SQLite（本地开发，开箱即用）
DATABASE_URL=sqlite:///./data/market_memory.db
# PostgreSQL（生产环境，取消下行注释并配置连接信息）
# DATABASE_URL=postgresql://user:password@localhost:5432/market_memory
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10

# ===== RAG 向量检索 =====
RAG_ENABLED=true
RAG_SIMILAR_DAYS_COUNT=5
RAG_QDRANT_PATH=./data/qdrant_storage
