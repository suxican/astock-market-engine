# ===== AI API 配置 =====
AI_PROVIDER=openai

# Claude API（AI_PROVIDER=claude 时使用）
CLAUDE_API_KEY=
CLAUDE_API_BASE=https://api.anthropic.com
CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenAI / DeepSeek 兼容接口（AI_PROVIDER=openai 时使用）
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.deepseek.com/v1
OPENAI_MODEL=deepseek-chat

# ===== 飞书通知 =====
FEISHU_WEBHOOK_URL=

# ===== 服务配置 =====
HOST=0.0.0.0
PORT=8005
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ===== 前端 =====
NEXT_PUBLIC_API_BASE_URL=http://localhost:8005

# ===== 认证 =====
# 生产环境必须修改！缺失时后端拒绝启动
JWT_SECRET=change-me-to-a-random-string-in-production

# ===== 数据库 =====
DATABASE_URL=sqlite:///./data/market_memory.db
# DB_POOL_SIZE=5
# DB_MAX_OVERFLOW=10

# ===== RAG 向量检索 =====
RAG_ENABLED=true
RAG_SIMILAR_DAYS_COUNT=5
RAG_QDRANT_PATH=./data/qdrant_storage
